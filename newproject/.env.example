# AICloudOps 配置文件

# 应用配置
APP_NAME=AICloudOps
APP_ENV=development
APP_DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# ============================================================
# 大模型 API 配置 (DeepSeek / Qwen3)
# ============================================================
# DeepSeek 申请地址: https://platform.deepseek.com/
# Qwen3 申请地址: https://dashscope.console.aliyun.com/
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# LLM 限流配置（防止 API 滥用）
LLM_RATE_LIMIT_ENABLED=true
LLM_RATE_LIMIT_PER_HOUR=100

# ============================================================
# 数据库配置
# ============================================================
# 数据库类型: sqlite（单机） 或 mysql（生产环境）
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///./data/aicops.db

# MySQL 配置（当 DATABASE_TYPE=mysql 时使用）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=aicops
MYSQL_PASSWORD=aicops_pass_2024
MYSQL_DATABASE=aicops

# ============================================================
# Redis 配置
# ============================================================
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0

# Redis 缓存配置
REDIS_CACHE_EXPIRE=300
REDIS_SESSION_EXPIRE=3600
REDIS_METRICS_EXPIRE=5

# ============================================================
# Docker Compose 专用变量（仅 docker-compose.yml 读取，后端 Settings 会自动忽略）
# ============================================================
REDIS_PORT=6379
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=aicops_root_2024
ADMINER_PORT=8080

# ============================================================
# 演示模式（Demo Mode）
# ============================================================
# 开启后，对预设 prompt 返回编排好的固定响应，绕过 LLM 和输入级安全拦截
# 用于视频录制、功能演示等需要 100% 可复现结果的场景
DEMO_MODE=false
