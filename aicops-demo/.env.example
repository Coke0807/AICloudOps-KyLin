# AICloudOps 配置文件

# 应用配置
APP_NAME=AICloudOps
APP_ENV=development
APP_DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 大模型 API 配置 (DeepSeek / Qwen3)
# DeepSeek 申请地址: https://platform.deepseek.com/
# Qwen3 申请地址: https://dashscope.console.aliyun.com/
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# 数据库配置 (SQLite)
DATABASE_URL=sqlite:///./data/aicops.db
